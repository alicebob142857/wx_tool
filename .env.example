# Local fallback: call the hosted exporter directly.
WX_EXPORTER_BASE_URL=https://down.mptext.top
WX_EXPORTER_AUTH_KEY=

# Recommended production mode: GitHub Actions calls the Cloudflare auth broker.
AUTH_SERVICE_URL=
AUTH_SERVICE_TOKEN=

DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-chat
DEEPSEEK_BASE_URL=https://api.deepseek.com

LOOKBACK_HOURS=36
MAX_ARTICLES_PER_RUN=60
OCR_MAX_IMAGES=8
OCR_TIMEOUT_MS=60000
CLASSIFIER_MODE=deepseek

