{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "wx-job-monitor-auth",
  "main": "src/index.ts",
  "compatibility_date": "2026-07-17",
  "workers_dev": true,
  "preview_urls": false,
  "observability": {
    "enabled": true
  },
  "kv_namespaces": [
    {
      "binding": "AUTH_KV",
      "id": "4634e79382f14e939d31666ff6ce6953"
    }
  ],
  "vars": {
    "ALLOWED_ORIGIN": "https://alicebob142857.github.io",
    "GITHUB_REPOSITORY": "alicebob142857/wx_tool"
  }
}
