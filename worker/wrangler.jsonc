{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "wx-job-monitor-auth",
  "main": "src/index.ts",
  "compatibility_date": "2026-07-17",
  "workers_dev": true,
  "observability": {
    "enabled": true
  },
  "kv_namespaces": [
    {
      "binding": "AUTH_KV",
      "id": "REPLACE_WITH_KV_NAMESPACE_ID"
    }
  ],
  "vars": {
    "ALLOWED_ORIGIN": "*",
    "GITHUB_REPOSITORY": ""
  }
}

