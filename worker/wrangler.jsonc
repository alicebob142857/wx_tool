{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "wx-job-monitor-auth",
  "main": "src/index.ts",
  "compatibility_date": "2026-07-17",
  "workers_dev": true,
  "preview_urls": false,
  "observability": {
    "enabled": true
  },
  "kv_namespaces": [
    {
      "binding": "AUTH_KV",
      "id": "4634e79382f14e939d31666ff6ce6953"
    }
  ],
  "d1_databases": [
    {
      "binding": "JOB_DB",
      "database_name": "wx-job-monitor-db",
      "database_id": "1146b9de-77da-4750-ab31-884a9d26c03d",
      "migrations_dir": "migrations"
    }
  ],
  "vars": {
    "ALLOWED_ORIGIN": "https://alicebob142857.github.io",
    "GITHUB_REPOSITORY": "alicebob142857/wx_tool",
    "SITE_PASSWORD_HASH": "ed973eef7e60c5160501b1738faebfab44126426271c646386609ffbd74802bf"
  }
}
