{
  "name": "wx-humanities-job-monitor",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "collect": "tsx src/run.ts",
    "smoke": "tsx scripts/smoke.ts",
    "check": "tsc -p tsconfig.json --noEmit && tsc -p worker/tsconfig.json --noEmit",
    "test": "node --import tsx --test tests/**/*.test.ts",
    "site:build-history": "node --import tsx scripts/build-static-history.ts",
    "site:serve": "node scripts/serve-site.mjs",
    "worker:dev": "wrangler dev --config worker/wrangler.jsonc",
    "worker:deploy": "wrangler deploy --config worker/wrangler.jsonc",
    "db:migrate": "wrangler d1 migrations apply wx-job-monitor-db --remote --config worker/wrangler.jsonc"
  },
  "dependencies": {
    "cheerio": "^1.1.2",
    "dotenv": "^17.2.3"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^5.20260710.1",
    "@types/node": "^22.15.3",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3",
    "wrangler": "^4.47.0"
  }
}
